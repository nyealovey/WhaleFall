# 1) HTTP 默认入口：保留给 IP 直接访问，也作为未命中域名规则时的兜底。
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    access_log /var/log/nginx/whalefall_access.log;
    error_log /var/log/nginx/whalefall_error.log warn;

    root /app/app/static;
    index index.html index.htm;

    location /static/ {
        alias /app/app/static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # React 控制台(`/console`)构建产物。旧站点继续由 Flask 处理根路径。
    location = /console {
        alias /app/frontend/dist/index.html;
        add_header Cache-Control "no-store";
    }

    location = /console/ {
        alias /app/frontend/dist/index.html;
        add_header Cache-Control "no-store";
    }

    location = /console/index.html {
        alias /app/frontend/dist/index.html;
        add_header Cache-Control "no-store";
    }

    location ^~ /console/assets/ {
        alias /app/frontend/dist/assets/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    location ^~ /console/ {
        alias /app/frontend/dist/;
        try_files $uri $uri/ /console/index.html;
    }

    location = /api/v1/scheduler {
        return 301 /api/v1/scheduler/;
    }

    location ^~ /api/v1/scheduler/ {
        proxy_pass http://127.0.0.1:5002;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        proxy_intercept_errors on;
        error_page 502 503 504 /50x.html;
    }

    location / {
        proxy_pass http://127.0.0.1:5001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        proxy_intercept_errors on;
        error_page 502 503 504 /50x.html;
    }

    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;

    location = /404.html {
        root /usr/share/nginx/html;
        internal;
    }

    location = /50x.html {
        root /usr/share/nginx/html;
        internal;
    }
}

# 2) 域名走 HTTPS：把下面两个域名替换成你的正式域名。
server {
    listen 80;
    listen [::]:80;
    server_name ${WHALEFALL_NGINX_SERVER_NAMES};

    return 301 https://$host$request_uri;
}

# 3) HTTPS 默认入口：不支持 IP 直连 HTTPS，避免证书与 IP 不匹配时仍打到应用。
server {
    listen 443 ssl http2 default_server;
    listen [::]:443 ssl http2 default_server;
    server_name _;

    ssl_certificate ${WHALEFALL_NGINX_SSL_CERTIFICATE};
    ssl_certificate_key ${WHALEFALL_NGINX_SSL_CERTIFICATE_KEY};
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    return 421;
}

