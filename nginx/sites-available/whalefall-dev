server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;

    # 日志配置
    access_log /var/log/nginx/whalefall_access.log;
    error_log /var/log/nginx/whalefall_error.log warn;

    # 根目录
    root /app/app/static;
    index index.html index.htm;

    # 静态文件服务
    location /static/ {
        alias /app/app/static/;
        expires 1h;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # React 默认前端构建产物。旧 Flask 站点统一挂载到 `/old`。
    location = /console {
        return 404;
    }

    location ^~ /console/ {
        return 404;
    }

    location = / {
        default_type text/html;
        alias /app/frontend/dist/index.html;
        add_header Cache-Control "no-store";
    }

    location = /index.html {
        default_type text/html;
        alias /app/frontend/dist/index.html;
        add_header Cache-Control "no-store";
    }

    location ^~ /assets/ {
        alias /app/frontend/dist/assets/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    location = /old {
        return 302 /old/;
    }

    location ^~ /old/static/ {
        alias /app/app/static/;
        expires 1h;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    location ^~ /old/ {
        rewrite ^/old(/.*)$ $1 break;
        proxy_pass http://127.0.0.1:5001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_set_header X-Forwarded-Prefix /old;

        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        proxy_intercept_errors on;
        error_page 502 503 504 /50x.html;
    }

    # 健康检查
    location /health {
        proxy_pass http://127.0.0.1:5001/health;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # 健康检查特殊设置
        proxy_connect_timeout 5s;
        proxy_send_timeout 5s;
        proxy_read_timeout 5s;
    }

    # 代理到 Flask API。
    location ^~ /api/ {
        proxy_pass http://127.0.0.1:5001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # 超时设置 - 增加超时时间以支持数据库连接测试
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # 缓冲设置
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        # 错误处理
        proxy_intercept_errors on;
        error_page 502 503 504 /50x.html;
    }

    # React SPA 路由兜底。
    location / {
        root /app/frontend/dist;
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-store";
    }

    # 错误页面
    error_page 404 /404.html;
    error_page 500 502 503 504 /50x.html;

    location = /404.html {
        root /usr/share/nginx/html;
        internal;
    }

    location = /50x.html {
        root /usr/share/nginx/html;
        internal;
    }
}
